# Claude API key — get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Lokalise API v2 token — Profile → API tokens
LOKALISE_API_KEY=

# Lokalise project ID (the one whose keys this service translates)
LOKALISE_PROJECT_ID=

# Shared secret used to HMAC-SHA256 sign incoming Lokalise webhooks.
# Must be at least 32 characters. Paste the same value into the
# Lokalise webhook "secret" field.
WEBHOOK_SECRET=change-me-to-a-32-plus-char-random-string

# HTTP port for the webhook listener
PORT=3000

# development | production
NODE_ENV=development
